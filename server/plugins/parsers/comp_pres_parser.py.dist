#!/usr/bin/env python3
"""Parser for ROV compensator pressure sensor data.

Parses comma-separated log files with six compensator pressure channels and
returns the JSON-formatted plugin data used by OpenVDM's Data Dashboard.
"""

import logging
import sys
from os.path import dirname, realpath
import pandas as pd

sys.path.append(dirname(dirname(dirname(dirname(realpath(__file__))))))

from server.lib.openvdm_plugin import OpenVDMCSVParser

FIELDS = ['hdr', 'comp1', 'comp2', 'comp3', 'comp4', 'comp5', 'comp6']
PROC_COLS = ['date_time', 'comp1', 'comp2', 'comp3', 'comp4', 'comp5', 'comp6']

ROUNDING = {
    'comp1': 3,
    'comp2': 3,
    'comp3': 3,
    'comp4': 3,
    'comp5': 3,
    'comp6': 3,
}


class CompPresParser(OpenVDMCSVParser):
    """Parser for ROV compensator pressure sensor log files."""

    MAX_DELTA_T = pd.Timedelta('10 seconds')

    def __init__(self, start_dt=None, stop_dt=None, time_format=None,
                 skip_header=False, use_openvdm_api=False):
        super().__init__(None, PROC_COLS, start_dt=start_dt, stop_dt=stop_dt,
                         time_format=time_format, skip_header=skip_header,
                         use_openvdm_api=use_openvdm_api)

    def parse(self, filepath):
        """Parse the compensator pressure file and return plugin data dict."""
        raw_data = {col: [] for col in self.proc_cols}
        errors = []
        try:
            for lineno, timestamp_str, remainder, fields in self.read_lines_with_timestamps(filepath):
                field_data = dict(zip(FIELDS, fields))
                try:
                    comp1 = float(field_data['comp1']) if field_data.get('comp1') else None
                    comp2 = float(field_data['comp2']) if field_data.get('comp2') else None
                    comp3 = float(field_data['comp3']) if field_data.get('comp3') else None
                    comp4 = float(field_data['comp4']) if field_data.get('comp4') else None
                    comp5 = float(field_data['comp5']) if field_data.get('comp5') else None
                    comp6 = float(field_data['comp6']) if field_data.get('comp6') else None
                    raw_data['date_time'].append(timestamp_str)
                    raw_data['comp1'].append(comp1)
                    raw_data['comp2'].append(comp2)
                    raw_data['comp3'].append(comp3)
                    raw_data['comp4'].append(comp4)
                    raw_data['comp5'].append(comp5)
                    raw_data['comp6'].append(comp6)
                except Exception as err:
                    errors.append(lineno)
                    logging.debug("Line %s skipped: %s", lineno, err)
        except Exception as err:
            logging.error("Failed to read file %s: %s", filepath, err)
            return None

        if not raw_data['date_time']:
            logging.warning("No valid data in file: %s", filepath)
            return None

        df = pd.DataFrame(raw_data)
        df['date_time'] = pd.to_datetime(df['date_time'], errors='coerce')
        df = df.dropna(subset=['date_time'])
        df = df.dropna(thresh=6)
        if df.empty:
            logging.warning("Dataframe empty after filtering: %s", filepath)
            return None

        if self.start_dt or self.stop_dt:
            df = self.crop_data(df)
        if df.empty:
            logging.warning("Dataframe empty after cropping: %s", filepath)
            return None

        df = df.set_index('date_time')
        df['deltaT'] = df.index.to_series().diff()

        self.add_row_validity_stat([len(df), len(errors)])
        self.add_time_bounds_stat([df.index.min().to_pydatetime(), df.index.max().to_pydatetime()])
        self.add_bounds_stat([round(df['deltaT'].min().total_seconds(), 3),
                              round(df['deltaT'].max().total_seconds(), 3)], 'DeltaT Bounds', 'seconds')
        self.add_value_validity_stat([len(df[df['deltaT'] <= self.MAX_DELTA_T]),
                                      len(df[df['deltaT'] > self.MAX_DELTA_T])], 'DeltaT Validity')
        self.add_bounds_stat([round(df['comp1'].min(), ROUNDING['comp1']),
                              round(df['comp1'].max(), ROUNDING['comp1'])], 'Compensator 1', '%')
        self.add_bounds_stat([round(df['comp2'].min(), ROUNDING['comp2']),
                              round(df['comp2'].max(), ROUNDING['comp2'])], 'Compensator 2', '%')
        self.add_bounds_stat([round(df['comp3'].min(), ROUNDING['comp3']),
                              round(df['comp3'].max(), ROUNDING['comp3'])], 'Compensator 3', '%')
        self.add_bounds_stat([round(df['comp4'].min(), ROUNDING['comp4']),
                              round(df['comp4'].max(), ROUNDING['comp4'])], 'Compensator 4', '%')
        self.add_bounds_stat([round(df['comp5'].min(), ROUNDING['comp5']),
                              round(df['comp5'].max(), ROUNDING['comp5'])], 'Compensator 5', '%')
        self.add_bounds_stat([round(df['comp6'].min(), ROUNDING['comp6']),
                              round(df['comp6'].max(), ROUNDING['comp6'])], 'Compensator 6', '%')

        for name, total, bad in [
            ('Rows', len(df) + len(errors), len(errors)),
            ('DeltaT', len(df), len(df[df['deltaT'] > self.MAX_DELTA_T])),
        ]:
            rate = bad / total
            if rate > 0.25:
                self.add_quality_test_failed(name)
            elif rate > 0.10:
                self.add_quality_test_warning(name)
            else:
                self.add_quality_test_passed(name)

        df = self.resample_data(df)
        df = self.round_data(df, ROUNDING)
        df = df.set_index('date_time')

        for col, label in [('comp1', 'Compensator 1'), ('comp2', 'Compensator 2'),
                            ('comp3', 'Compensator 3'), ('comp4', 'Compensator 4'),
                            ('comp5', 'Compensator 5'), ('comp6', 'Compensator 6')]:
            viz = {'data': [], 'unit': '%', 'label': label}
            for ts, row in df.iterrows():
                if pd.notna(row[col]):
                    ts_obj = pd.Timestamp(ts)
                    if ts_obj.tzinfo is None:
                        ts_obj = ts_obj.tz_localize('UTC')
                    viz['data'].append([int(ts_obj.timestamp() * 1000), row[col]])
            self.add_visualization_data(viz)

        self.send_error_msg(errors, filepath)
        self.plugin_data = self._sanitize_for_json(self.plugin_data)
        return self.plugin_data


if __name__ == "__main__":
    CompPresParser.run_cli()
