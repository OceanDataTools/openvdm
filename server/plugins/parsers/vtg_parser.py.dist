#!/usr/bin/env python3
"""
FILE:  vtg_parser.py

USAGE:  vtg_parser.py [-h] [-v+] [--timeFormat] [--startDT] [--stopDT] [--noMag] <dataFile>

DESCRIPTION:  Parse the supplied NMEA-formtted VTG file and return the json-
              formatted string used by OpenVDM as part of it's Data dashboard.

  OPTIONS:  [-h] Return the help message.
            [-v+] Increase verbosity (default: warning)
            [--timeFormat] date/time format to use when parsing datafile, default
                           yyyy-mm-ddTHH:MM:SS.sssZ
            [--startTS] optional start crop time (strptime format)
            [--stopTS] optional stop crop time (strptime format)
            [--noMag] skip the COG magnetic processing
            <dataFile> Full or relative path of the data file to process.

REQUIREMENTS:  Python3.11
               Python Modules:
                   numpy==2.4.0
                   pandas==2.3.0

     BUGS:
    NOTES:
   AUTHOR:  Webb Pinner
  VERSION:  2.14
  CREATED:  2016-08-29
 REVISION:  2025-12-30
"""

import sys
import logging
from datetime import datetime
from os.path import dirname, realpath
import pandas as pd
import numpy as np
import json

sys.path.append(dirname(dirname(dirname(dirname(realpath(__file__))))))

from server.lib.openvdm_plugin import OpenVDMCSVParser

PROC_COLS = ['date_time','cog_t','cog_m','sog_kts','sog_kph']

VTG_FIELDS = [
    "header",
    "cog_t",
    "T",
    "cog_m",
    "M",
    "sog_kts",
    "N",
    "sog_kph",
    "K",
    "checksum"
]

ROUNDING = {
    'cog_t': 3,
    'cog_m': 3,
    'sog_kts': 3,
    'sog_kph': 3
}


class VTGParser(OpenVDMCSVParser):
    """Parser for NMEA VTG files, fully refactored like GGAParser."""

    MAX_DELTA_T = pd.Timedelta('10 seconds')

    MIN_COG = 0
    MAX_COG = 360

    MAX_SOG_KTS = 25
    MAX_SOG_KPH = MAX_SOG_KTS * 1.852

    def __init__(self, start_dt=None, stop_dt=None, time_format=None,
                 skip_header=False, use_openvdm_api=False, no_mag=False):
        self.no_mag = no_mag
        proc_cols = PROC_COLS if not no_mag else [col for col in PROC_COLS if col != 'cog_m']
        super().__init__(None, proc_cols, start_dt=start_dt, stop_dt=stop_dt,
                         time_format=time_format, skip_header=skip_header,
                         use_openvdm_api=use_openvdm_api)

    def parse(self, filepath):
        raw_data = {col: [] for col in self.proc_cols}
        errors = []

        # -------------------------
        # Read and parse VTG lines
        # -------------------------
        try:
            for lineno, timestamp_str, remainder, fields in self.read_lines_with_timestamps(filepath, nmea_filter='VTG'):
                logging.debug(f"{timestamp_str}{self.timestamp_separator}{remainder}")

                # Map fields to VTG_FIELDS
                vtg_data = dict(zip(VTG_FIELDS, fields))

                try:
                    cog_t = float(vtg_data['cog_t']) if vtg_data['cog_t'] else None
                    cog_m = float(vtg_data['cog_m']) if (not self.no_mag and vtg_data['cog_m']) else None
                    sog_kts = float(vtg_data['sog_kts']) if vtg_data['sog_kts'] else None
                    sog_kph = float(vtg_data['sog_kph']) if vtg_data['sog_kph'] else None

                    raw_data['date_time'].append(timestamp_str)
                    raw_data['cog_t'].append(cog_t)
                    if not self.no_mag:
                        raw_data['cog_m'].append(cog_m)
                    raw_data['sog_kts'].append(sog_kts)
                    raw_data['sog_kph'].append(sog_kph)

                except Exception as err:
                    errors.append(lineno)
                    logging.debug("Line %s skipped due to parse error: %s", lineno, err)

        except Exception as err:
            logging.error("Failed to read file %s: %s", filepath, err)
            return None

        if not raw_data['date_time']:
            logging.warning("No valid VTG data in file: %s", filepath)
            return None

        # -------------------------
        # Build DataFrame
        # -------------------------
        df = pd.DataFrame(raw_data)
        df['date_time'] = pd.to_datetime(df['date_time'], errors='coerce')
        if df['date_time'].isna().all():
            logging.error("All timestamps could not be parsed; aborting.")
            return None
        df = df.dropna(subset=['date_time'])
        df = df.set_index('date_time')

        if self.start_dt or self.stop_dt:
            df = self.crop_data(df)
        if df.empty:
            logging.warning("Dataframe empty after cropping: %s", filepath)
            return None

        # -------------------------
        # DeltaT
        # -------------------------
        df['deltaT'] = df.index.to_series().diff()

        # -------------------------
        # Statistics
        # -------------------------
        logging.info("Tabulating statistics...")
        self.add_row_validity_stat([len(df), len(errors)])
        self.add_time_bounds_stat([df.index.min().to_pydatetime(),df.index.max().to_pydatetime()])
        self.add_bounds_stat([round(df['deltaT'].min().total_seconds(),3),
                              round(df['deltaT'].max().total_seconds(),3)], 'DeltaT Bounds', 'seconds')
        self.add_value_validity_stat([len(df[df['deltaT'] <= self.MAX_DELTA_T]),
                                      len(df[df['deltaT'] > self.MAX_DELTA_T])], 'DeltaT Validity')
        self.add_bounds_stat([round(df['cog_t'].min(), ROUNDING['cog_t']),
                              round(df['cog_t'].max(), ROUNDING['cog_t'])], "COG True Bounds", "deg")
        self.add_value_validity_stat([len(df[(df['cog_t'] >= self.MIN_COG) & (df['cog_t'] <= self.MAX_COG)]),
                                      len(df[(df['cog_t'] < self.MIN_COG) | (df['cog_t'] > self.MAX_COG)])], "COG True Validity")
        if not self.no_mag:
            self.add_bounds_stat([round(df['cog_m'].min(), ROUNDING['cog_m']),
                                  round(df['cog_m'].max(), ROUNDING['cog_m'])], "COG Magnetic Bounds", "deg")
            self.add_value_validity_stat([len(df[(df['cog_m'] >= self.MIN_COG) & (df['cog_m'] <= self.MAX_COG)]),
                                          len(df[(df['cog_m'] < self.MIN_COG) | (df['cog_m'] > self.MAX_COG)])], "COG Magnetic Validity")
        self.add_bounds_stat([round(df['sog_kts'].min(), ROUNDING['sog_kts']),
                              round(df['sog_kts'].max(), ROUNDING['sog_kts'])], 'SOG Knots Bounds', 'kts')
        self.add_value_validity_stat([len(df[df['sog_kts'] <= self.MAX_SOG_KTS]),
                                      len(df[df['sog_kts'] > self.MAX_SOG_KTS])], 'SOG Knots Validity')
        self.add_bounds_stat([round(df['sog_kph'].min(), ROUNDING['sog_kph']),
                              round(df['sog_kph'].max(), ROUNDING['sog_kph'])], 'SOG KPH Bounds', 'kph')
        self.add_value_validity_stat([len(df[df['sog_kph'] <= self.MAX_SOG_KPH]),
                                      len(df[df['sog_kph'] > self.MAX_SOG_KPH])], 'SOG KPH Validity')

        # -------------------------
        # Quality tests
        # -------------------------
        logging.info("Running quality tests...")
        quality_checks = [
            ('Rows', len(df)+len(errors), len(errors)),
            ('DeltaT', len(df), len(df[df['deltaT'] > self.MAX_DELTA_T])),
            ('SOG kts', len(df), len(df[df['sog_kts'] > self.MAX_SOG_KTS])),
            ('SOG kph', len(df), len(df[df['sog_kph'] > self.MAX_SOG_KPH])),
            ('COG True', len(df), len(df[(df['cog_t'] < self.MIN_COG) | (df['cog_t'] > self.MAX_COG)]))
        ]

        if not self.no_mag:
            quality_checks.append(("COG Magnetic", len(df), len(df[(df['cog_m'] < self.MIN_COG) | (df['cog_m'] > self.MAX_COG)])))

        for col, total, bad in quality_checks:
            error_rate = bad / total
            if error_rate > 0.25:
                self.add_quality_test_failed(col)
            elif error_rate > 0.10:
                self.add_quality_test_warning(col)
            else:
                self.add_quality_test_passed(col)

        # -------------------------
        # Resample and round
        # -------------------------
        df = self.resample_data(df)
        df = self.round_data(df, ROUNDING)
        df = df.set_index('date_time')

        # -------------------------
        # Visualization
        # -------------------------
        logging.info("Building visualization datasets...")

        for col, unit, label in [('cog_t', 'deg', 'COG True'),
                                 ('cog_m', 'deg', 'COG Magnetic'),
                                 ('sog_kts', 'kts', 'SOG kts'),
                                 ('sog_kph', 'kph', 'SOG kph')]:
            if col == 'cog_m' and self.no_mag:
                continue

            visualizer_data_obj = {'data': [], 'unit': unit, 'label': label}
            for ts, row in df.iterrows():
                if pd.notna(row[col]):
                    ts = pd.Timestamp(ts)
                    if ts.tzinfo is None:
                        ts = ts.tz_localize('UTC')
                    epoch_ms = int(ts.timestamp() * 1000)
                    visualizer_data_obj['data'].append([epoch_ms, row[col]])

            self.add_visualization_data(visualizer_data_obj)

        # -------------------------
        # Send errors to OpenVDM
        # -------------------------
        self.send_error_msg(errors, filepath)

    # -----------------------------
    # CLI hooks for custom arguments
    # -----------------------------
    @classmethod
    def add_cli_arguments(cls, parser):
        parser.add_argument('--noMag', action='store_true', default=False, help='Skip COG Magnetic')

    @classmethod
    def _extract_custom_cli_kwargs(cls, args):
        return {'no_mag': getattr(args, 'noMag', False)}

# -------------------------------------------------------------------------------------
# Standalone CLI
# -------------------------------------------------------------------------------------
if __name__ == "__main__":
    VTGParser.run_cli()
