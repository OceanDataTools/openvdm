#!/usr/bin/env python3
"""
FILE:  mwd_parser.py

USAGE:  mwd_parser.py [-h] [-v+] [--timeFormat] [--startDT] [--stopDT] [--noMag] <dataFile>

DESCRIPTION:  Parse the supplied NMEA-formtted MWD file and return the json-
              formatted string used by OpenVDM as part of it's Data dashboard.

  OPTIONS:  [-h] Return the help message.
            [-v+] Increase verbosity (default: warning)
            [--timeFormat] date/time format to use when parsing datafile, default
                           yyyy-mm-ddTHH:MM:SS.sssZ
            [--startTS] optional start crop time (strptime format)
            [--stopTS] optional stop crop time (strptime format)
            [--noMag] skip the Direction magnetic processing
            <dataFile> Full or relative path of the data file to process.

REQUIREMENTS:  Python3.11
               Python Modules:
                   numpy==2.4.0
                   pandas==2.3.0

     BUGS:
    NOTES:
   AUTHOR:  Webb Pinner
  VERSION:  2.14
  CREATED:  2016-08-29
 REVISION:  2025-12-30
"""

import sys
import logging
from datetime import datetime
from os.path import dirname, realpath
import pandas as pd
import numpy as np
import json

sys.path.append(dirname(dirname(dirname(dirname(realpath(__file__))))))

from server.lib.openvdm_plugin import OpenVDMCSVParser

PROC_COLS = ['date_time','dir_t','dir_m','spd_kts','spd_mph']

FIELDS = [
    "header",
    "dir_t",
    "T",
    "dir_m",
    "M",
    "spd_kts",
    "N",
    "spd_mph",
    "M_checksum"
]

ROUNDING = {
    'dir_t': 2,
    'dir_m': 2,
    'spd_kts': 2,
    'spd_mph': 2
}


class MWDParser(OpenVDMCSVParser):
    """Parser for NMEA MWD files, fully refactored like GGAParser."""

    MAX_DELTA_T = pd.Timedelta('10 seconds')

    MIN_DIR = 0.0
    MAX_DIR = 360.0

    MAX_SPD_KTS = 80
    MAX_SPD_MPH = MAX_SPD_KTS * 1.15078

    def __init__(self, start_dt=None, stop_dt=None, time_format=None,
                 skip_header=False, use_openvdm_api=False, no_mag=False):
        self.no_mag = no_mag
        proc_cols = PROC_COLS if not no_mag else [col for col in PROC_COLS if col != 'dir_m']
        super().__init__(None, proc_cols, start_dt=start_dt, stop_dt=stop_dt,
                         time_format=time_format, skip_header=skip_header,
                         use_openvdm_api=use_openvdm_api)

    def parse(self, filepath):
        raw_data = {col: [] for col in self.proc_cols}
        errors = []

        # -------------------------
        # Read and parse MWD lines
        # -------------------------
        try:
            for lineno, timestamp_str, remainder, fields in self.read_lines_with_timestamps(filepath, nmea_filter='MWD'):
                logging.debug(f"{timestamp_str}{self.timestamp_separator}{remainder}")

                # Map fields to FIELDS
                mwd_data = dict(zip(FIELDS, fields))

                try:
                    dir_t = float(mwd_data['dir_t']) if mwd_data['dir_t'] else None
                    dir_m = float(mwd_data['dir_m']) if (not self.no_mag and mwd_data['dir_m']) else None
                    spd_kts = float(mwd_data['spd_kts']) if mwd_data['spd_kts'] else None
                    spd_mph = float(mwd_data['spd_mph']) if mwd_data['spd_mph'] else None

                    raw_data['date_time'].append(timestamp_str)
                    raw_data['dir_t'].append(dir_t)
                    if not self.no_mag:
                        raw_data['dir_m'].append(dir_m)
                    raw_data['spd_kts'].append(spd_kts)
                    raw_data['spd_mph'].append(spd_mph)

                except Exception as err:
                    errors.append(lineno)
                    logging.debug("Line %s skipped due to parse error: %s", lineno, err)

        except Exception as err:
            logging.error("Failed to read file %s: %s", filepath, err)
            return None

        if not raw_data['date_time']:
            logging.warning("No valid MWD data in file: %s", filepath)
            return None

        # -------------------------
        # Build DataFrame
        # -------------------------
        df = pd.DataFrame(raw_data)
        df['date_time'] = pd.to_datetime(df['date_time'], errors='coerce')
        if df['date_time'].isna().all():
            logging.error("All timestamps could not be parsed; aborting.")
            return None
        df = df.dropna(subset=['date_time'])
        df = df.set_index('date_time')

        if self.start_dt or self.stop_dt:
            df = self.crop_data(df)
        if df.empty:
            logging.warning("Dataframe empty after cropping: %s", filepath)
            return None

        # -------------------------
        # DeltaT
        # -------------------------
        df['deltaT'] = df.index.to_series().diff()

        # -------------------------
        # Statistics
        # -------------------------
        logging.info("Tabulating statistics...")
        self.add_row_validity_stat([len(df), len(errors)])
        self.add_time_bounds_stat([df.index.min().to_pydatetime(),df.index.max().to_pydatetime()])
        self.add_bounds_stat([round(df['deltaT'].min().total_seconds(),3),
                              round(df['deltaT'].max().total_seconds(),3)], 'DeltaT Bounds', 'seconds')
        self.add_value_validity_stat([len(df[df['deltaT'] <= self.MAX_DELTA_T]),
                                      len(df[df['deltaT'] > self.MAX_DELTA_T])], 'DeltaT Validity')
        self.add_bounds_stat([round(df['dir_t'].min(), ROUNDING['dir_t']),
                              round(df['dir_t'].max(), ROUNDING['dir_t'])], "Direction True Bounds", "deg")
        self.add_value_validity_stat([len(df[(df['dir_t'] >= self.MIN_DIR) & (df['dir_t'] <= self.MAX_DIR)]),
                                      len(df[(df['dir_t'] < self.MIN_DIR) | (df['dir_t'] > self.MAX_DIR)])], "Direction True Validity")
        if not self.no_mag:
            self.add_bounds_stat([round(df['dir_m'].min(), ROUNDING['dir_m']),
                                  round(df['dir_m'].max(), ROUNDING['dir_m'])], "Direction Magnetic Bounds", "deg")
            self.add_value_validity_stat([len(df[(df['dir_m'] >= self.MIN_DIR) & (df['dir_m'] <= self.MAX_DIR)]),
                                          len(df[(df['dir_m'] < self.MIN_DIR) | (df['dir_m'] > self.MAX_DIR)])], "Direction Magnetic Validity")
        self.add_bounds_stat([round(df['spd_kts'].min(), ROUNDING['spd_kts']),
                              round(df['spd_kts'].max(), ROUNDING['spd_kts'])], 'Speed Knots Bounds', 'kts')
        self.add_value_validity_stat([len(df[df['spd_kts'] <= self.MAX_SPD_KTS]),
                                      len(df[df['spd_kts'] > self.MAX_SPD_KTS])], 'Speed Knots Validity')
        self.add_bounds_stat([round(df['spd_mph'].min(), ROUNDING['spd_mph']),
                              round(df['spd_mph'].max(), ROUNDING['spd_mph'])], 'Speed MPH Bounds', 'mph')
        self.add_value_validity_stat([len(df[df['spd_mph'] <= self.MAX_SPD_MPH]),
                                      len(df[df['spd_mph'] > self.MAX_SPD_MPH])], 'Speed MPH Validity')

        # -------------------------
        # Quality tests
        # -------------------------
        logging.info("Running quality tests...")
        quality_checks = [
            ('Rows', len(df)+len(errors), len(errors)),
            ('DeltaT', len(df), len(df[df['deltaT'] > self.MAX_DELTA_T])),
            ('Speed, kts', len(df), len(df[df['spd_kts'] > self.MAX_SPD_KTS])),
            ('Speed, mph', len(df), len(df[df['spd_mph'] > self.MAX_SPD_MPH])),
            ('Direction, True', len(df), len(df[(df['dir_t'] < self.MIN_DIR) | (df['dir_t'] > self.MAX_DIR)]))
        ]

        if not self.no_mag:
            quality_checks.append(("Direction, Magnetic", len(df), len(df[(df['dir_m'] < self.MIN_DIR) | (df['dir_m'] > self.MAX_DIR)])))

        for col, total, bad in quality_checks:
            error_rate = bad / total
            if error_rate > 0.25:
                self.add_quality_test_failed(col)
            elif error_rate > 0.10:
                self.add_quality_test_warning(col)
            else:
                self.add_quality_test_passed(col)

        # -------------------------
        # Resample and round
        # -------------------------
        df = self.resample_data(df)
        df = self.round_data(df, ROUNDING)
        df = df.set_index('date_time')

        # -------------------------
        # Visualization
        # -------------------------
        logging.info("Building visualization datasets...")

        for col, unit, label in [('dir_t', 'deg', 'Direction True'),
                                 ('dir_m', 'deg', 'Direction Mag.'),
                                 ('spd_kts', 'kts', 'Speed'),
                                 ('spd_mph', 'mph', 'Speed')]:
            if col == 'dir_m' and self.no_mag:
                continue

            visualizer_data_obj = {'data': [], 'unit': unit, 'label': label}
            for ts, row in df.iterrows():
                if pd.notna(row[col]):
                    ts = pd.Timestamp(ts)
                    if ts.tzinfo is None:
                        ts = ts.tz_localize('UTC')
                    epoch_ms = int(ts.timestamp() * 1000)
                    visualizer_data_obj['data'].append([epoch_ms, row[col]])

            self.add_visualization_data(visualizer_data_obj)

        # -------------------------
        # Send errors to OpenVDM
        # -------------------------
        self.send_error_msg(errors, filepath)

    # -----------------------------
    # CLI hooks for custom arguments
    # -----------------------------
    @classmethod
    def add_cli_arguments(cls, parser):
        parser.add_argument('--noMag', action='store_true', default=False, help='Skip Direction Magnetic')

    @classmethod
    def _extract_custom_cli_kwargs(cls, args):
        return {'no_mag': getattr(args, 'noMag', False)}

# -------------------------------------------------------------------------------------
# Standalone CLI
# -------------------------------------------------------------------------------------
if __name__ == "__main__":
    MWDParser.run_cli()
