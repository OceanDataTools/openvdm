#!/usr/bin/env python3
"""Parse Sprint navigation data files for OpenVDM data dashboard.

Reads timestamped CSV records and extracts latitude/longitude track positions,
computing velocity from successive fixes and producing a GeoJSON FeatureCollection.
"""

import json
import logging
import sys
from os.path import dirname, realpath
from geopy import Point
from geopy.distance import great_circle
import numpy as np
import pandas as pd

sys.path.append(dirname(dirname(dirname(dirname(realpath(__file__))))))

from server.lib.openvdm_plugin import OpenVDMCSVParser

PROC_COLS = ['date_time', 'latitude', 'longitude']

FIELDS = ['hdr', 'roll', 'pitch', 'heading', 'orientation_status', 'latitude', 'longitude',
          'position_status', 'velocity_fwd', 'velocity_stbd', 'velocity_down',
          'altitude', 'altitude_status', 'depth', 'depth_used']

ROUNDING = {
    'latitude': 8,
    'longitude': 8,
    'velocity': 3
}

MAX_VELOCITY = 10


class SprintParser(OpenVDMCSVParser):
    """Parser for Sprint USBL/navigation sensor data files."""

    MAX_DELTA_T = pd.Timedelta('10 seconds')

    def __init__(self, start_dt=None, stop_dt=None, time_format=None,
                 skip_header=False, use_openvdm_api=False):
        super().__init__(None, PROC_COLS, start_dt=start_dt, stop_dt=stop_dt,
                         time_format=time_format, skip_header=skip_header,
                         use_openvdm_api=use_openvdm_api)

    def parse(self, filepath):
        """Parse a Sprint navigation data file."""
        raw_data = {col: [] for col in self.proc_cols}
        errors = []

        try:
            for lineno, timestamp_str, remainder, fields in self.read_lines_with_timestamps(filepath):
                logging.debug("%s%s%s", timestamp_str, self.timestamp_separator, remainder)
                field_data = dict(zip(FIELDS, fields))

                try:
                    latitude = float(field_data['latitude']) if field_data.get('latitude', '').strip() else None
                    longitude = float(field_data['longitude']) if field_data.get('longitude', '').strip() else None

                    # lat=0, lon=0 indicates a bad fix
                    if latitude == 0 and longitude == 0:
                        continue

                    raw_data['date_time'].append(timestamp_str)
                    raw_data['latitude'].append(latitude)
                    raw_data['longitude'].append(longitude)

                except Exception as err:
                    errors.append(lineno)
                    logging.debug("Line %s skipped due to parse error: %s", lineno, err)

        except Exception as err:
            logging.error("Failed to read file %s: %s", filepath, err)
            return None

        if not raw_data['date_time']:
            logging.warning("No valid Sprint data in file: %s", filepath)
            return None

        df = pd.DataFrame(raw_data)
        df['date_time'] = pd.to_datetime(df['date_time'], errors='coerce')
        if df['date_time'].isna().all():
            logging.error("All timestamps could not be parsed; aborting.")
            return None
        df = df.dropna(subset=['date_time'])
        df = df.set_index('date_time')

        if self.start_dt or self.stop_dt:
            df = self.crop_data(df)
        if df.empty:
            logging.warning("Dataframe empty after cropping: %s", filepath)
            return None

        df['deltaT'] = df.index.to_series().diff()

        logging.info("Computing distances and velocities...")
        df['point'] = df.apply(
            lambda row: Point(latitude=row['latitude'], longitude=row['longitude']), axis=1)
        df['point_next'] = df['point'].shift(1)
        df.loc[df['point_next'].isna(), 'point_next'] = None
        df['distance'] = df.apply(
            lambda row: great_circle(row['point'], row['point_next']).nm
            if row['point_next'] is not None else float('nan'), axis=1)
        df = df.drop(columns=['point_next', 'point'])
        df['velocity'] = df['distance'] / (df['deltaT'].dt.total_seconds() / 3600)

        logging.info("Tabulating statistics...")
        self.add_row_validity_stat([len(df), len(errors)])
        self.add_geobounds_stat([round(df['latitude'].max(), ROUNDING['latitude']),
                                 round(df['longitude'].max(), ROUNDING['longitude']),
                                 round(df['latitude'].min(), ROUNDING['latitude']),
                                 round(df['longitude'].min(), ROUNDING['longitude'])])
        self.add_bounds_stat([round(df['velocity'].min(), ROUNDING['velocity']),
                              999999.999 if np.isinf(df['velocity'].max())
                              else round(df['velocity'].max(), ROUNDING['velocity'])],
                             'Velocity Bounds', 'kts')
        self.add_value_validity_stat([len(df[df['velocity'] <= MAX_VELOCITY]),
                                      len(df[df['velocity'] > MAX_VELOCITY])], 'Velocity Validity')
        self.add_total_value_stat([round(df['distance'].sum(), 3)], 'Distance Traveled', 'nm')
        self.add_time_bounds_stat([df.index.min().to_pydatetime(), df.index.max().to_pydatetime()])
        self.add_bounds_stat([round(df['deltaT'].min().total_seconds(), 3),
                              round(df['deltaT'].max().total_seconds(), 3)], 'DeltaT Bounds', 'seconds')
        self.add_value_validity_stat([len(df[df['deltaT'] <= self.MAX_DELTA_T]),
                                      len(df[df['deltaT'] > self.MAX_DELTA_T])], 'DeltaT Validity')

        logging.info("Running quality tests...")
        quality_checks = [
            ('Rows', len(df) + len(errors), len(errors)),
            ('DeltaT', len(df), len(df[df['deltaT'] > self.MAX_DELTA_T])),
            ('Velocity', len(df), len(df[df['velocity'] > MAX_VELOCITY])),
        ]
        for col, total, bad in quality_checks:
            error_rate = bad / total
            if error_rate > 0.25:
                self.add_quality_test_failed(col)
            elif error_rate > 0.10:
                self.add_quality_test_warning(col)
            else:
                self.add_quality_test_passed(col)

        # resample resets index — date_time becomes a column again
        df = self.resample_data(df)
        df = self.round_data(df, ROUNDING)

        logging.info("Building visualization datasets...")
        events = np.split(df, np.where(np.isnan(df['latitude']))[0])
        events = [event[~np.isnan(event.latitude)] for event in events
                  if not isinstance(event, np.ndarray)]
        events = [event for event in events if not event.empty]

        visualizer_data_obj = {'type': 'FeatureCollection', 'features': []}
        for event in events:
            feature = {
                'type': 'Feature',
                'geometry': {
                    'type': 'LineString',
                    'coordinates': json.loads(event[['longitude', 'latitude']].to_json(orient='values'))
                },
                'properties': {
                    'coordTimes': json.loads(event['date_time'].to_json(orient='values')),
                    'name': filepath
                }
            }
            visualizer_data_obj['features'].append(feature)

        self.add_visualization_data(visualizer_data_obj)
        self.send_error_msg(errors, filepath)


if __name__ == "__main__":
    SprintParser.run_cli()
