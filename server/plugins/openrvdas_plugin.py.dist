#!/usr/bin/env python3
"""
FILE:  openrvdas_plugin.py

USAGE:  openrvdas_plugin.py [-h] [--dataType] <dataFile>

DESCRIPTION:  This python script interprets raw files created by the OpenRVDAS
    Data Acquision System.  Depending on the command-line arguments, the script
    returns the data type(s) of the file or a sub-sampled and json-formatted
    version of the original file to stdout.  The json-formatted file is used by
    OpenVDM as part of it's Data dashboard.

    NOTE: Multiple parsers may intentionally process the same file.
    Each parser is responsible for filtering only the sentences it understands.

  OPTIONS:  [-h] Return the help message.
            [--dataType] Return the datatype of the file as defined in the
                fileTypeFilter array.
            <dataFile> Full or relative path of the data file to process.

REQUIREMENTS:  Python3.11

     BUGS:
    NOTES:
   AUTHOR:  Webb Pinner
  VERSION:  2.14
  CREATED:  2016-10-23
 REVISION:  2025-04-30
"""

import sys
import os
import json
import fnmatch
import logging
from os.path import dirname, realpath

sys.path.append(dirname(dirname(dirname(realpath(__file__)))))

from server.lib.openvdm_plugin import OpenVDMPlugin, NpEncoder
from server.plugins.parsers.gga_parser   import GGAParser
# from server.plugins.parsers.vtg_parser   import VTGParser
# from server.plugins.parsers.hdt_parser   import HDTParser
from server.plugins.parsers.met_parser   import MetParser
from server.plugins.parsers.svp_parser   import SVPParser
from server.plugins.parsers.tsg_parser   import SBE45TSGParser as TSGParser
from server.plugins.parsers.twind_parser import TWindParser

# -------------------------------
# File type filters
# -------------------------------
fileTypeFilters = [
    # {"data_type":"gnsspo000045-gga",   "regex": "*gnsspo000045*",      "parser": "GGA",    'parser_options':{}},
    # {"data_type":"gnsspo000045-vtg",   "regex": "*gnsspo000045*",      "parser": "VTG",    'parser_options':{}},
    {"data_type":"gga",   "regex": "*/raw/POSMV_GGA-*.txt",      "parser": "GGA",    'parser_options':{}},
    # {"data_type":"hdt",   "regex": "*/raw/POSMV-*.txt",      "parser": "HDT",    'parser_options':{}},
    {"data_type":"met",   "regex": "*/raw/MET-*.txt",        "parser": "Met",    'parser_options':{}},
    {"data_type":"svp",   "regex": "*/raw/SVP-*.txt",        "parser": "SVP",    'parser_options':{}},
    {"data_type":"tsg",   "regex": "*/raw/TSG_Raw-*.txt",    "parser": "TSG",    'parser_options':{}},
    {"data_type":"twind", "regex": "*/proc/TrueWind-*.txt",  "parser": "TWind",  'parser_options':{}},
    # {"data_type":"vtg",   "regex": "*/raw/POSMV-*.txt",      "parser": "VTG",    'parser_options':{}},
]

# -------------------------------
# Plugin class
# -------------------------------
class OpenRVDASPlugin(OpenVDMPlugin):
    PARSER_MAP = {
        "GGA": GGAParser,
        # "HDT": HDTParser,
        "Met": MetParser,
        "SVP": SVPParser,
        "TSG": TSGParser,
        "TWind": TWindParser,
        # "VTG": VTGParser,
    }

    def __init__(self):
        super().__init__(fileTypeFilters)

    def _get_parsers(self, filepath):
        matches = [f for f in self.file_type_filters if fnmatch.fnmatch(filepath, f["regex"])]
        if not matches:
            logging.debug("No file type filters matched %s", filepath)
            return []

        parsers = []
        for f in matches:
            parser_name = f.get("parser")
            parser_cls = self.PARSER_MAP.get(parser_name)
            if not parser_cls:
                logging.warning("Unknown parser '%s' for %s", parser_name, filepath)
                continue
            try:
                parser = parser_cls(**f.get("parser_options", {}))
                parsers.append((f["data_type"], parser))
            except Exception as exc:
                logging.exception("Failed to instantiate parser %s for %s: %s", parser_name, filepath, exc)
        return parsers

    def parse_file(self, filepath):
        parsers = self._get_parsers(filepath)
        if not parsers:
            logging.debug("No parsers matched file %s", filepath)
            return {}

        results = {}
        for data_type, parser in parsers:
            try:
                parser.parse(filepath)
                if parser.plugin_data:
                    results[data_type] = parser.plugin_data
            except Exception as exc:
                logging.exception("Parser '%s' failed for file '%s': %s", data_type, filepath, exc)
        return results

# -------------------------------
# Module-level function for worker
# -------------------------------
def process_file(filepath):
    """
    Module-level wrapper for Gearman worker compatibility.
    """
    plugin = OpenRVDASPlugin()
    return plugin.parse_file(filepath)

# -------------------------------
# CLI support
# -------------------------------
if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(description='OpenVDM plugin for OpenRVDAS')
    parser.add_argument('--dataType', action='store_true', help='return the dataType of the file')
    parser.add_argument('-v', '--verbosity', dest='verbosity', default=0, action='count', help='Increase verbosity')
    parser.add_argument('dataFile', metavar='dataFile', help='the raw data file to process')
    args = parser.parse_args()

    LOGGING_FORMAT = '%(asctime)-15s %(levelname)s - %(message)s'
    logging.basicConfig(format=LOGGING_FORMAT)
    LOG_LEVELS = {0: logging.WARNING, 1: logging.INFO, 2: logging.DEBUG}
    args.verbosity = min(args.verbosity, max(LOG_LEVELS))
    logging.getLogger().setLevel(LOG_LEVELS[args.verbosity])

    if not os.path.isfile(args.dataFile):
        logging.error("File not found: %s", args.dataFile)
        sys.exit(1)
    elif os.stat(args.dataFile).st_size == 0:
        logging.warning("File is empty: %s", args.dataFile)
        sys.exit(0)

    plugin = OpenRVDASPlugin()

    if args.dataType:
        data_types = plugin.get_data_types(args.dataFile)
        if not data_types:
            logging.warning("File is of unknown type: %s", args.dataFile)
            sys.exit(1)
        print(",".join(sorted(data_types)))
        sys.exit(0)

    print(plugin.get_json_str(args.dataFile))
